# World source:
# procedural - old generated map
# osm        - geometry from OpenStreetMap only
# hybrid     - OSM geometry + Google enrichment
# google     - alias to hybrid for quick experiments
WORLD_SOURCE=procedural

# Remote world center
# Example:
# MAP_CENTER_LAT=50.172909282887964
# MAP_CENTER_LNG=30.085456624118343
MAP_CENTER_LAT=
MAP_CENTER_LNG=
MAP_RADIUS_METERS=350

# Raster target size for the in-game grid
# 192 is the current native project size.
# These values now affect both procedural and remote world modes.
MAP_GRID_WIDTH=192
MAP_GRID_HEIGHT=192

# OSM
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# Google enrichment for hybrid mode
GOOGLE_MAPS_API_KEY=

# Cache TTL (default: 1 year)
WORLD_CACHE_TTL_SECONDS=31536000

# Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
